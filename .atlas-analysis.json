  "keyFeatures": [
    "Native ORAS backend for OCI registries",
    "Atomic locking and state versioning",
    "Built-in compression and retry logic",
    "GitHub Action with PR comments and summaries",
    "GHCR authentication integration",
    "Automatic stale lock cleanup",
    "Historical state version retention"
  ],
  "publicApiSurface": [
    "ghoten init - Initialize working directory with ORAS backend",
    "ghoten plan - Show infrastructure changes",
    "ghoten apply - Apply infrastructure changes",
    "ghoten destroy - Destroy managed infrastructure",
    "ghoten validate - Validate configuration files",
    "ghoten fmt - Format configuration files",
    "backend \"oras\" - ORAS backend configuration block",
    "vmvarela/ghoten@v1 - GitHub Action",
    "TF_BACKEND_ORAS_* - Environment variables for backend configuration"
  ]
